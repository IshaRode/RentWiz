# RentWiz Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI Explanations (optional) ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
USE_AI_EXPLANATIONS=true

# ─── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=RentWiz API
APP_VERSION=1.0.0

# ─── Deal Thresholds (INR/month) ───────────────────────────────────────────────
GOOD_DEAL_THRESHOLD=2000
OVERPRICED_THRESHOLD=-2000

# ─── ML Model Paths ────────────────────────────────────────────────────────────
MODEL_PATH=app/models/rent_model.joblib
PREPROCESSOR_PATH=app/models/preprocessor.joblib

# ─── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true
SCRAPER_MAX_LISTINGS=50

# ─── CORS (comma-separated) ────────────────────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]
